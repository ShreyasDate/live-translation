{
  "manifest_version": 3,
  "name": "Live Translation",
  "version": "1.0",
  "description": "Real-time voice translation in Google Meet",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Translation"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
